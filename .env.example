# Claude integration
# Option A: Anthropic API key (worker calls API directly)
ANTHROPIC_API_KEY=

# Option B: Claude Code CLI path (worker spawns `claude -p "..."`). Default: "claude" on PATH.
CLAUDE_CLI=claude
# Model alias for CLI (sonnet|opus|haiku). Default: sonnet.
CLAUDE_MODEL=sonnet
# Worker auto-approves tool use (file edits, bash). Set to 1 for read-only replies.
CLAUDE_SAFE=0

# Worker polling fallback interval (ms). Realtime is primary; polling is backup.
WORKER_POLL_INTERVAL_MS=5000

---
import Layout from '../layouts/Layout.astro';
---
<Layout title="MoTaskBot">
  <!-- iOS install banner (lives above bottom tab bar) -->
  <div id="ios-install-banner" class="hidden fixed left-3 right-3 z-[90] card p-3 flex items-center gap-3 shadow-2xl md:hidden animate-slide-up" style="bottom: calc(env(safe-area-inset-bottom) + 76px);">
    <div class="w-9 h-9 rounded-xl bg-accent flex items-center justify-center text-white font-bold flex-shrink-0 text-sm">M</div>
    <div class="flex-1 text-[12px] leading-snug text-fg">
      Install: tap
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block align-text-bottom"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
      Share → <span class="text-accent font-medium">Add to Home Screen</span>
    </div>
    <button id="ios-banner-close" aria-label="Dismiss" class="btn-ghost !p-1 text-fg-muted text-lg leading-none">×</button>
  </div>

  <!-- Login screen -->
  <div id="login-screen" class="hidden fixed inset-0 z-[100] bg-bg flex items-center justify-center p-6 animate-fade-in">
    <form id="login-form" class="card w-full max-w-sm p-6 md:p-8 space-y-5 animate-scale-in shadow-2xl mx-4">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-md bg-accent flex items-center justify-center text-white font-bold">M</div>
        <div>
          <div class="text-base font-semibold">MoTaskBot</div>
          <div class="text-xs text-fg-muted">Sign in to continue</div>
        </div>
      </div>
      <div class="space-y-4">
        <div>
          <label class="text-xs text-fg-muted mb-2 block">Email</label>
          <input id="login-email" class="input" type="email" autocomplete="email" autocapitalize="off" autocorrect="off" required />
        </div>
        <div>
          <label class="text-xs text-fg-muted mb-2 block">Password</label>
          <input id="login-password" class="input" type="password" autocomplete="current-password" required />
        </div>
      </div>
      <div id="login-error" class="hidden text-xs text-status-failed"></div>
      <button type="submit" id="login-submit" class="btn-primary w-full justify-center py-4 text-base font-semibold">Sign in</button>
    </form>
  </div>

  <!-- Floating background orbs -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="orb orb-4"></div>

  <div id="app-root" class="flex flex-col md:flex-row h-[100dvh] overflow-hidden relative hidden animate-fade-in" style="z-index: 10;">

    <!-- Desktop sidebar (hidden on mobile) -->
    <aside class="hidden md:flex w-72 border-r border-border bg-bg-raised flex-col">
      <div class="px-4 py-3 border-b border-border flex items-center gap-2">
        <div class="w-7 h-7 rounded-md bg-accent flex items-center justify-center text-white text-xs font-bold">M</div>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-semibold">MoTaskBot</div>
          <div class="text-[11px] text-fg-dim truncate" id="worker-status-desktop">worker: unknown</div>
        </div>
      </div>
      <div class="p-3 space-y-3 flex-1 overflow-y-auto">
        <section>
          <div class="flex items-center justify-between px-1 mb-1.5">
            <h3 class="text-[11px] font-semibold uppercase tracking-wider text-fg-muted">Projects</h3>
            <button id="new-project-btn-desktop" class="btn-ghost !px-2 !py-1 text-xs">+ new</button>
          </div>
          <ul id="project-list-desktop" class="space-y-0.5"></ul>
        </section>
      </div>
    </aside>

    <!-- Main view area -->
    <main class="flex-1 flex flex-col overflow-hidden">

      <!-- Top header (mobile + desktop) -->
      <header class="pt-safe px-4 md:px-6 border-b border-border/70 bg-bg-raised/90 md:bg-transparent backdrop-blur-xl supports-[backdrop-filter]:bg-bg-raised/70 md:supports-[backdrop-filter]:bg-transparent sticky top-0 z-20">
        <div class="flex items-center gap-2 md:gap-3 py-2.5 md:py-3 min-h-[52px]">
          <div class="md:hidden w-9 h-9 rounded-xl bg-accent flex items-center justify-center text-white text-sm font-bold shadow-md shadow-accent/30">M</div>
          <div class="flex-1 min-w-0">
            <h1 id="view-title" class="text-[17px] md:text-sm font-semibold truncate leading-tight">Tasks</h1>
            <p id="view-subtitle" class="text-[11px] text-fg-muted truncate leading-tight" data-worker>realtime: connecting…</p>
          </div>
          <button id="search-toggle" aria-label="Search" class="btn-ghost !p-2.5 min-h-[40px] min-w-[40px] rounded-full">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
          <button id="theme-toggle" aria-label="Theme" class="btn-ghost !p-2.5 min-h-[40px] min-w-[40px] rounded-full">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>
      </header>

      <!-- Search bar (collapsible) -->
      <div id="search-bar" class="hidden px-4 md:px-6 py-2 border-b border-border bg-bg-raised">
        <input id="search-input" class="input" placeholder="Search tasks, sessions, projects…" autocomplete="off" />
      </div>

      <!-- Content area (tab switched) -->
      <section class="flex-1 overflow-y-auto pb-24 md:pb-4" style="padding-bottom: calc(env(safe-area-inset-bottom) + 80px);">

        <!-- View: Tasks feed -->
        <div id="view-tasks" class="view">
          <div class="px-3 md:px-6 pt-3 pb-1 flex items-center gap-2 overflow-x-auto scrollbar-none md:flex-wrap">
            <select id="tasks-filter-chat" class="input !w-auto !py-1.5 !px-3 text-xs !rounded-full flex-shrink-0">
              <option value="">All chats</option>
            </select>
            <select id="tasks-filter-status" class="input !w-auto !py-1.5 !px-3 text-xs !rounded-full flex-shrink-0">
              <option value="">All statuses</option>
              <option value="pending">pending</option>
              <option value="running">running</option>
              <option value="completed">completed</option>
              <option value="failed">failed</option>
            </select>
            <button id="tasks-clear-completed" class="btn-ghost !py-1.5 !px-3 text-xs !rounded-full border border-border flex-shrink-0 md:ml-auto md:border-0">Clear completed</button>
          </div>
          <div id="tasks-empty" class="h-full flex flex-col items-center justify-center text-fg-dim text-sm text-center px-6 py-20 gap-2">
            <div class="text-4xl mb-2">✨</div>
            <div>No tasks yet.</div>
            <div class="text-[11px]">Tap <span class="text-accent">+</span> to send one to Claude.</div>
          </div>
          <ul id="tasks-feed" class="px-4 md:px-6 py-4 space-y-3 hidden"></ul>
        </div>

        <!-- View: Projects -->
        <div id="view-projects" class="view hidden">
          <ul id="projects-feed" class="px-4 md:px-6 py-4 space-y-3"></ul>
        </div>

        <!-- View: Sessions (Claude Code) -->
        <div id="view-sessions" class="view hidden">
          <ul id="sessions-feed" class="px-4 md:px-6 py-4 space-y-3"></ul>
        </div>

        <!-- View: Chat (pure Q&A, no tools) -->
        <div id="view-chat" class="view hidden">
          <div id="chat-messages" class="px-3 md:px-6 py-3 space-y-3"></div>
          <!-- Chat input: fixed above tab bar on mobile, normal flow on desktop -->
          <div id="chat-input-bar" class="fixed md:static left-0 right-0 z-20 border-t border-border bg-bg-raised/95 backdrop-blur-xl supports-[backdrop-filter]:bg-bg-raised/80 px-3 md:px-4 py-2 hidden" style="bottom: calc(env(safe-area-inset-bottom) + 56px);">
            <div class="max-w-3xl mx-auto">
              <div class="flex items-end gap-2">
                <textarea id="chat-input" class="input !rounded-2xl min-h-[44px] max-h-40 resize-none !py-2.5" rows="1" placeholder="Ask Claude…"></textarea>
                <button id="chat-send" class="btn-primary !rounded-full !w-11 !h-11 !min-h-[44px] !p-0 flex-shrink-0 justify-center" aria-label="Send">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
              </div>
              <div class="flex items-center justify-between mt-1.5 px-1">
                <select id="chat-model" class="bg-transparent text-[11px] text-fg-muted border-none !p-0 !pr-4 focus:outline-none cursor-pointer">
                  <option value="haiku">⚡ haiku</option>
                  <option value="sonnet">✦ sonnet</option>
                  <option value="opus">◆ opus</option>
                </select>
                <span class="text-[10px] text-fg-dim">No tools · pure chat</span>
              </div>
            </div>
          </div>
          <div class="hidden md:block" style="height: 140px;"></div>
          <div class="md:hidden" style="height: 140px;"></div>
        </div>

        <!-- View: Usage -->
        <div id="view-usage" class="view hidden">
          <div class="px-4 md:px-6 py-4 space-y-4 max-w-3xl mx-auto">

            <!-- Running indicator -->
            <div id="usage-live" class="card p-4 flex items-center gap-3 hidden">
              <span class="status-dot status-running"></span>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium truncate"><span id="usage-live-title"></span></div>
                <div class="text-[11px] text-fg-muted truncate"><span id="usage-live-meta"></span></div>
              </div>
            </div>

            <!-- Progress windows -->
            <div class="card p-4 space-y-3">
              <div class="flex items-center justify-between">
                <div class="text-xs uppercase tracking-wider text-fg-muted">5-hour window</div>
                <div id="usage-5h-reset" class="text-[10px] text-fg-dim">resets in —</div>
              </div>
              <div class="h-2 bg-bg-elevated rounded-full overflow-hidden">
                <div id="usage-5h-bar" class="h-full bg-accent transition-all duration-500" style="width:0%"></div>
              </div>
              <div class="flex items-center justify-between text-[11px]">
                <span id="usage-5h-label" class="text-fg-muted">0 tokens · 0 tasks</span>
                <span id="usage-5h-cost" class="text-fg-dim">—</span>
              </div>
            </div>

            <div class="card p-4 space-y-3">
              <div class="flex items-center justify-between">
                <div class="text-xs uppercase tracking-wider text-fg-muted">Weekly (rolling 7d)</div>
                <div id="usage-week-reset" class="text-[10px] text-fg-dim">resets in —</div>
              </div>
              <div class="h-2 bg-bg-elevated rounded-full overflow-hidden">
                <div id="usage-week-bar" class="h-full bg-status-completed transition-all duration-500" style="width:0%"></div>
              </div>
              <div class="flex items-center justify-between text-[11px]">
                <span id="usage-week-label" class="text-fg-muted">0 tokens · 0 tasks</span>
                <span id="usage-week-cost" class="text-fg-dim">—</span>
              </div>
            </div>

            <!-- Plan limits (editable) -->
            <div class="card p-4 space-y-2">
              <div class="flex items-center justify-between">
                <div class="text-xs uppercase tracking-wider text-fg-muted">Plan limits (optional)</div>
                <button id="usage-edit-limits" class="btn-ghost !py-1 !px-2 text-xs">Edit</button>
              </div>
              <p class="text-[11px] text-fg-muted">Set your plan cap to see % used. Stored locally.</p>
              <div class="grid grid-cols-2 gap-3 text-xs">
                <div><span class="text-fg-dim">5h cap:</span> <span id="usage-limit-5h-display">not set</span></div>
                <div><span class="text-fg-dim">Weekly cap:</span> <span id="usage-limit-week-display">not set</span></div>
              </div>
            </div>

            <!-- By model 30d -->
            <div class="card p-4 space-y-2">
              <div class="text-xs uppercase tracking-wider text-fg-muted">By model (last 30d)</div>
              <ul id="usage-by-model" class="text-sm space-y-1"></ul>
            </div>

          </div>
        </div>

        <!-- Modal: edit plan limits -->
        <div id="limits-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-md z-50 flex items-end md:items-center justify-center">
          <div class="card w-full md:max-w-md md:rounded-lg rounded-t-3xl rounded-b-none p-5 pb-[max(env(safe-area-inset-bottom),1rem)] space-y-4 animate-slide-up md:animate-scale-in">
            <div class="md:hidden sheet-handle -mt-3 mb-1"></div>
            <h2 class="text-base font-semibold">Plan limits</h2>
            <p class="text-xs text-fg-muted">Tokens cap per rolling window. Stored in your browser.</p>
            <div class="space-y-3">
              <div>
                <label class="text-xs text-fg-muted mb-1 block">5-hour limit (tokens)</label>
                <input id="limits-5h" type="number" class="input" placeholder="e.g. 500000" />
              </div>
              <div>
                <label class="text-xs text-fg-muted mb-1 block">Weekly limit (tokens)</label>
                <input id="limits-week" type="number" class="input" placeholder="e.g. 5000000" />
              </div>
            </div>
            <div class="flex justify-end gap-2">
              <button id="limits-cancel" class="btn-ghost">Cancel</button>
              <button id="limits-save" class="btn-primary">Save</button>
            </div>
          </div>
        </div>

      </section>

      <!-- Mobile FAB -->
      <button
        id="fab-new-task"
        aria-label="New task"
        class="md:hidden fixed right-4 z-30 w-14 h-14 rounded-full bg-accent hover:bg-accent-hover text-white shadow-lg flex items-center justify-center active:scale-95 transition-all duration-200 animate-fade-in"
        style="bottom: calc(env(safe-area-inset-bottom) + 72px);"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>

      <!-- Desktop "+" button -->
      <button id="desktop-new-task" class="hidden md:inline-flex btn-primary fixed bottom-5 right-5 z-30">+ New Task</button>

      <button id="logout-btn" class="hidden md:inline-flex btn-ghost fixed top-3 right-5 text-xs">Sign out</button>

      <!-- Bottom tab bar (mobile only) -->
      <nav class="md:hidden fixed bottom-0 left-0 right-0 z-20 bg-bg-raised/90 backdrop-blur-2xl supports-[backdrop-filter]:bg-bg-raised/75 border-t border-border/60 pb-[env(safe-area-inset-bottom)]">
        <ul class="flex items-stretch px-1">
          <li class="flex-1">
            <button data-tab="tasks" class="tab-btn w-full py-2 flex flex-col items-center gap-0.5 text-[10px] font-medium transition-colors duration-200 active:text-accent min-h-[56px]" aria-label="Tasks">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
              <span>Tasks</span>
            </button>
          </li>
          <li class="flex-1">
            <button data-tab="projects" class="tab-btn w-full py-2 flex flex-col items-center gap-0.5 text-[10px] font-medium transition-colors duration-200 active:text-accent min-h-[56px]" aria-label="Projects">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
              <span>Projects</span>
            </button>
          </li>
          <li class="flex-1">
            <button data-tab="sessions" class="tab-btn w-full py-2 flex flex-col items-center gap-0.5 text-[10px] font-medium transition-colors duration-200 active:text-accent min-h-[56px]" aria-label="Sessions">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              <span>Sessions</span>
            </button>
          </li>
          <li class="flex-1">
            <button data-tab="chat" class="tab-btn w-full py-2 flex flex-col items-center gap-0.5 text-[10px] font-medium transition-colors duration-200 active:text-accent min-h-[56px]" aria-label="Chat">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
              <span>Chat</span>
            </button>
          </li>
          <li class="flex-1">
            <button data-tab="usage" class="tab-btn w-full py-2 flex flex-col items-center gap-0.5 text-[10px] font-medium transition-colors duration-200 active:text-accent min-h-[56px]" aria-label="Usage">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
              <span>Usage</span>
            </button>
          </li>
        </ul>
      </nav>
    </main>
  </div>

  <!-- Modal: Quick Task (unified) -->
  <div id="task-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-md z-50 flex items-end md:items-center justify-center animate-fade-in">
    <div class="card w-full md:max-w-xl md:rounded-lg rounded-t-3xl rounded-b-none p-0 max-h-[92dvh] md:max-h-[90dvh] flex flex-col animate-slide-up md:animate-scale-in">
      <div class="md:hidden sheet-handle"></div>
      <div class="px-4 md:px-5 py-2.5 md:py-3 border-b border-border flex items-center justify-between gap-3 sticky top-0 bg-bg-raised z-10 rounded-t-3xl md:rounded-t-lg">
        <h2 class="text-base font-semibold">New Task</h2>
        <button id="task-close" aria-label="Close" class="btn-ghost !p-2 !text-xl min-h-[40px] min-w-[40px] rounded-full">×</button>
      </div>

      <div class="flex-1 overflow-y-auto p-4 md:p-5 space-y-4">
        <!-- Target picker -->
        <div>
          <label class="text-xs text-fg-muted mb-1.5 block">Send to</label>
          <div id="target-selected" class="card p-3 flex items-center justify-between gap-3 cursor-pointer active:bg-bg-elevated">
            <div class="flex-1 min-w-0">
              <div id="target-label" class="text-sm font-medium truncate">Choose a session or project</div>
              <div id="target-sub" class="text-[11px] text-fg-muted truncate">Tap to pick</div>
            </div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-fg-dim"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </div>

        <!-- Title + instructions -->
        <div>
          <label class="text-xs text-fg-muted mb-1.5 block">Title <span class="text-fg-dim">(optional)</span></label>
          <input id="task-title" class="input" placeholder="Auto from first line" autocomplete="off" />
        </div>

        <div>
          <label class="text-xs text-fg-muted mb-1.5 block">Model</label>
          <select id="task-model" class="input">
            <option value="haiku">Haiku (cheapest, fast)</option>
            <option value="sonnet">Sonnet (balanced)</option>
            <option value="opus">Opus (most capable)</option>
          </select>
        </div>

        <div>
          <label class="text-xs text-fg-muted mb-1.5 block">Prompt</label>
          <textarea id="task-instructions" class="textarea min-h-[120px] md:min-h-[160px]" placeholder="What should Claude do?"></textarea>
        </div>
      </div>

      <div class="px-4 md:px-5 py-3 border-t border-border sticky bottom-0 bg-bg-raised pb-[env(safe-area-inset-bottom)]">
        <button id="task-create" class="btn-primary w-full justify-center py-3 text-base font-semibold">
          Send to Claude
        </button>
      </div>
    </div>
  </div>

  <!-- Modal: Target picker (session / new project) -->
  <div id="target-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-md z-[60] flex items-end md:items-center justify-center animate-fade-in">
    <div class="card w-full md:max-w-lg md:rounded-lg rounded-t-3xl rounded-b-none p-0 max-h-[88dvh] md:max-h-[92dvh] flex flex-col animate-slide-up md:animate-scale-in">
      <div class="md:hidden sheet-handle"></div>
      <div class="px-4 md:px-5 py-2.5 md:py-3 border-b border-border flex items-center justify-between gap-3 sticky top-0 bg-bg-raised z-10 rounded-t-3xl md:rounded-t-lg">
        <h2 class="text-base font-semibold">Send task to…</h2>
        <button id="target-close" aria-label="Close" class="btn-ghost !p-2 !text-xl rounded-full">×</button>
      </div>
      <div class="px-4 md:px-5 pt-3 pb-2">
        <input id="target-search" class="input" placeholder="Search sessions, projects…" autocomplete="off" />
      </div>
      <div class="flex-1 overflow-y-auto px-3 py-2 space-y-1" id="target-list"></div>
    </div>
  </div>

  <!-- Modal: Task detail (bottom sheet) -->
  <div id="detail-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-md z-50 flex items-end md:items-center justify-center animate-fade-in">
    <div class="card w-full md:max-w-3xl md:rounded-lg rounded-t-3xl rounded-b-none md:max-h-[85vh] max-h-[92dvh] flex flex-col animate-slide-up md:animate-scale-in">
      <div class="md:hidden sheet-handle"></div>
      <div class="px-4 md:px-5 py-2.5 md:py-3 border-b border-border flex items-center justify-between gap-3 sticky top-0 bg-bg-raised z-10 rounded-t-3xl md:rounded-t-lg">
        <div class="min-w-0 flex-1">
          <h2 id="detail-title" class="text-sm font-semibold truncate"></h2>
          <div id="detail-meta" class="text-[11px] text-fg-muted mt-0.5 truncate"></div>
        </div>
        <div class="flex items-center gap-1">
          <button id="detail-delete" aria-label="Delete task" class="btn-ghost !p-2 text-fg-dim hover:text-status-failed">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
          </button>
          <button id="detail-close" aria-label="Close" class="btn-ghost !p-2 !text-xl">×</button>
        </div>
      </div>
      <div class="flex-1 overflow-y-auto p-4 md:p-5 space-y-4 pb-[env(safe-area-inset-bottom)]">
        <div>
          <h3 class="text-[10px] uppercase tracking-wider text-fg-muted mb-1">Prompt</h3>
          <pre id="detail-instructions" class="text-xs font-mono whitespace-pre-wrap bg-bg-elevated rounded-md p-3 border border-border"></pre>
        </div>
        <div>
          <h3 class="text-[10px] uppercase tracking-wider text-fg-muted mb-1">Result</h3>
          <pre id="detail-result" class="text-xs font-mono whitespace-pre-wrap bg-bg-elevated rounded-md p-3 border border-border min-h-[100px]"></pre>
        </div>
        <div id="detail-error-wrap" class="hidden">
          <h3 class="text-[10px] uppercase tracking-wider text-status-failed mb-1">Error</h3>
          <pre id="detail-error" class="text-xs font-mono whitespace-pre-wrap bg-bg-elevated rounded-md p-3 border border-status-failed/40"></pre>
        </div>
        <div class="border-t border-border pt-4">
          <h3 class="text-[10px] uppercase tracking-wider text-fg-muted mb-1.5">Reply / Continue</h3>
          <textarea id="detail-reply" class="textarea min-h-[80px] md:min-h-[100px]" placeholder="e.g. 'sí, procede' or more instructions"></textarea>
          <div class="flex gap-2 mt-3">
            <button id="detail-reply-yes" class="btn-ghost flex-1 md:flex-none justify-center py-3">Yes, proceed</button>
            <button id="detail-reply-send" class="btn-primary flex-1 md:flex-none justify-center py-3">Send reply</button>
          </div>
          <p class="text-[11px] text-fg-dim mt-2">Creates a new task in the same chat — Claude Code session resumes.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal: Theme selector -->
  <div id="theme-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-md z-50 flex items-end md:items-center justify-center animate-fade-in">
    <div class="card w-full md:max-w-sm md:rounded-lg rounded-t-3xl rounded-b-none p-0 flex flex-col animate-slide-up md:animate-scale-in pb-[env(safe-area-inset-bottom)]">
      <div class="md:hidden sheet-handle"></div>
      <div class="px-4 md:px-5 py-2.5 md:py-3 border-b border-border flex items-center justify-between gap-3 sticky top-0 bg-bg-raised z-10 rounded-t-3xl md:rounded-t-lg">
        <h2 class="text-base font-semibold">Choose Theme</h2>
        <button id="theme-close" aria-label="Close" class="btn-ghost !p-2 !text-xl rounded-full">×</button>
      </div>
      <div class="p-3 space-y-2 overflow-y-auto">
        <button data-theme="dark" class="theme-option w-full text-left px-4 py-3 rounded-md border border-border hover:border-accent hover:bg-bg-elevated transition-all">
          <div class="text-sm font-medium">Dark</div>
          <div class="text-xs text-fg-muted mt-0.5">Deep blacks with purple accent</div>
        </button>
        <button data-theme="nord" class="theme-option w-full text-left px-4 py-3 rounded-md border border-border hover:border-accent hover:bg-bg-elevated transition-all">
          <div class="text-sm font-medium">Nord</div>
          <div class="text-xs text-fg-muted mt-0.5">Cool arctic blues</div>
        </button>
        <button data-theme="solarized" class="theme-option w-full text-left px-4 py-3 rounded-md border border-border hover:border-accent hover:bg-bg-elevated transition-all">
          <div class="text-sm font-medium">Solarized</div>
          <div class="text-xs text-fg-muted mt-0.5">Precision colors for machines and people</div>
        </button>
        <button data-theme="dracula" class="theme-option w-full text-left px-4 py-3 rounded-md border border-border hover:border-accent hover:bg-bg-elevated transition-all">
          <div class="text-sm font-medium">Dracula</div>
          <div class="text-xs text-fg-muted mt-0.5">Dark vibrant theme</div>
        </button>
      </div>
    </div>
  </div>

  <script>
    import '../scripts/app.ts';
  </script>
</Layout>

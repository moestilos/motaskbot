---
import Layout from '../layouts/Layout.astro';
---
<Layout title="MoTaskBot — Dashboard">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-72 border-r border-border bg-bg-raised flex flex-col">
      <div class="px-4 py-3 border-b border-border flex items-center gap-2">
        <div class="w-7 h-7 rounded-md bg-accent flex items-center justify-center text-white text-xs font-bold">M</div>
        <div>
          <div class="text-sm font-semibold">MoTaskBot</div>
          <div class="text-[11px] text-fg-dim" id="worker-status">worker: unknown</div>
        </div>
      </div>

      <div class="p-3 space-y-3 flex-1 overflow-y-auto">
        <section>
          <div class="flex items-center justify-between px-1 mb-1.5">
            <h3 class="text-[11px] font-semibold uppercase tracking-wider text-fg-muted">Projects</h3>
            <button id="new-project-btn" class="btn-ghost !px-1.5 !py-0.5 text-xs">+ new</button>
          </div>
          <ul id="project-list" class="space-y-0.5"></ul>
        </section>

        <section id="chats-section" class="hidden">
          <div class="flex items-center justify-between px-1 mb-1.5">
            <h3 class="text-[11px] font-semibold uppercase tracking-wider text-fg-muted">Chats</h3>
            <button id="new-chat-btn" class="btn-ghost !px-1.5 !py-0.5 text-xs">+ new</button>
          </div>
          <ul id="chat-list" class="space-y-0.5"></ul>
        </section>
      </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 flex flex-col overflow-hidden">
      <header class="px-6 py-3 border-b border-border flex items-center justify-between">
        <div>
          <h1 id="main-title" class="text-sm font-semibold">Select a project</h1>
          <p id="main-subtitle" class="text-xs text-fg-muted"></p>
        </div>
        <button id="new-task-btn" class="btn-primary hidden">+ New Task</button>
      </header>

      <section class="flex-1 overflow-y-auto px-6 py-4">
        <div id="empty-state" class="h-full flex items-center justify-center text-fg-dim text-sm">
          Create a project to get started.
        </div>
        <ul id="task-list" class="space-y-2 hidden"></ul>
      </section>
    </main>
  </div>

  <!-- Modal: new task -->
  <div id="task-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center">
    <div class="card w-full max-w-xl p-5 space-y-4">
      <h2 class="text-base font-semibold">New Task</h2>
      <div class="space-y-3">
        <div>
          <label class="text-xs text-fg-muted mb-1 block">Chat</label>
          <select id="task-chat" class="input"></select>
        </div>
        <div>
          <label class="text-xs text-fg-muted mb-1 block">Title</label>
          <input id="task-title" class="input" placeholder="Short summary" />
        </div>
        <div>
          <label class="text-xs text-fg-muted mb-1 block">Instructions</label>
          <textarea id="task-instructions" class="textarea" placeholder="What should Claude do?"></textarea>
        </div>
      </div>
      <div class="flex justify-end gap-2">
        <button id="task-cancel" class="btn-ghost">Cancel</button>
        <button id="task-create" class="btn-primary">Create</button>
      </div>
    </div>
  </div>

  <!-- Modal: task detail -->
  <div id="detail-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center">
    <div class="card w-full max-w-3xl max-h-[85vh] flex flex-col">
      <div class="px-5 py-3 border-b border-border flex items-center justify-between">
        <div>
          <h2 id="detail-title" class="text-sm font-semibold"></h2>
          <div id="detail-meta" class="text-xs text-fg-muted mt-0.5"></div>
        </div>
        <button id="detail-close" class="btn-ghost">Close</button>
      </div>
      <div class="flex-1 overflow-y-auto p-5 space-y-4">
        <div>
          <h3 class="text-xs uppercase tracking-wider text-fg-muted mb-1">Instructions</h3>
          <pre id="detail-instructions" class="text-xs font-mono whitespace-pre-wrap bg-bg-elevated rounded p-3 border border-border"></pre>
        </div>
        <div>
          <h3 class="text-xs uppercase tracking-wider text-fg-muted mb-1">Result</h3>
          <pre id="detail-result" class="text-xs font-mono whitespace-pre-wrap bg-bg-elevated rounded p-3 border border-border min-h-[100px]"></pre>
        </div>
        <div id="detail-error-wrap" class="hidden">
          <h3 class="text-xs uppercase tracking-wider text-status-failed mb-1">Error</h3>
          <pre id="detail-error" class="text-xs font-mono whitespace-pre-wrap bg-bg-elevated rounded p-3 border border-status-failed/40"></pre>
        </div>
      </div>
    </div>
  </div>

  <script type="module" src="/src/scripts/app.ts"></script>
</Layout>
